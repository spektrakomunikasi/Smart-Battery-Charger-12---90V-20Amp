// ═══════════════════════════════════════════════════════════════
// LIBRARIES
// ═══════════════════════════════════════════════════════════════

#include <Arduino.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <OneWire.h>
#include <DallasTemperature.h>
#include <EEPROM.h>

// ═══════════════════════════════════════════════════════════════
// PIN CONFIGURATION
// ═══════════════════════════════════════════════════════════════

// ADC Inputs (Sensors)
#define PIN_ACS758_CURRENT      34      // ADC1_CH6 - Current sensor input (0.67-4.33V)
#define PIN_VOLTAGE_SENSE       35      // ADC1_CH7 - Voltage divider input (0-5V)

// Digital Inputs (Temperature)
#define PIN_TEMP_SENSOR         32      // OneWire - DS18B20 temperature sensor

// I2C (LCD Display)
#define PIN_LCD_SDA             21      // I2C SDA for LCD module
#define PIN_LCD_SCL             22      // I2C SCL for LCD module

// ═══════════════════════════════════════════════════════════════
// CONFIGURATION PARAMETERS
// ═══════════════════════════════════════════════════════════════

// ACS758 Current Sensor Parameters
#define ACS758_VREF_MID         2.5     // Output voltage at 0A (2.5V)
#define ACS758_SENSITIVITY      0.04    // Sensitivity: 40mV per Ampere
#define ACS758_ADC_RESOLUTION   4095    // 12-bit ADC
#define ACS758_VREF             5.0     // Reference voltage
#define ACS758_SAMPLES          20      // Samples for averaging

// Voltage Divider Parameters
// Divider ratio: 1.7M / (1.7M + 100k) = 90V input = 5V output
#define VOLTAGE_DIVIDER_RATIO   18.0    // 90V / 18 = 5V (for ADC)
#define VOLTAGE_ADC_RESOLUTION  4095    // 12-bit ADC
#define VOLTAGE_VREF            5.0     // Reference voltage

// Timing Configuration
#define LCD_REFRESH_MS          500     // LCD update every 500ms
#define SENSOR_READ_MS          100     // Sensor read every 100ms
#define TEMP_READ_MS            2000    // Temperature read every 2 seconds
#define SERIAL_DEBUG_MS         5000    // Serial debug every 5 seconds

// Safety Limits (Monitoring alerts only, no hardware control)
#define MAX_SAFE_CURRENT        32.0    // Alert if exceed (20A + 60% margin)
#define MAX_SAFE_VOLTAGE        95.0    // Alert if exceed (90V + 5% margin)
#define MAX_SAFE_TEMP           75.0    // Alert if exceed (70°C + margin)

// EEPROM Storage
#define EEPROM_SIZE             512
#define ADDR_CALIB_OFFSET       0

// ═══════════════════════════════════════════════════════════════
// GLOBAL OBJECTS
// ═══════════════════════════════════════════════════════════════

// LCD Display (I2C address 0x27 for 16x2 display)
LiquidCrystal_I2C lcd(0x27, 16, 2);

// Temperature Sensor
OneWire oneWire(PIN_TEMP_SENSOR);
DallasTemperature tempSensor(&oneWire);

// ═══════════════════════════════════════════════════════════════
// GLOBAL VARIABLES
// ═══════════════════════════════════════════════════════════════

// Sensor readings
float currentValue = 0.0;           // Current in Amperes
float voltageValue = 0.0;           // Voltage in Volts
float temperatureValue = 25.0;      // Temperature in Celsius
float powerValue = 0.0;             // Power in Watts (V × I)

// Calibration
float currentOffset = 0.0;          // ACS758 calibration offset

// Timing trackers
unsigned long lastLcdUpdate = 0;
unsigned long lastSensorRead = 0;
unsigned long lastTempRead = 0;
unsigned long lastDebugPrint = 0;

// Moving average buffers
#define FILTER_SIZE 10
float currentFilter[FILTER_SIZE];
float voltageFilter[FILTER_SIZE];
int filterIndex = 0;

// Alert flags
bool alertOverCurrent = false;
bool alertOverVoltage = false;
bool alertOverTemp = false;

// ═══════════════════════════════════════════════════════════════
// SETUP FUNCTION
// ═══════════════════════════════════════════════════════════════

void setup() {
  // Initialize serial for debugging
  Serial.begin(115200);
  delay(2000);  // Wait for serial to stabilize
  
  // Print welcome message
  Serial.println("\n\n╔════════════════════════════════════════════════╗");
  Serial.println("║   SMART BATTERY CHARGER - MONITORING v1.0      ║");
  Serial.println("║   Safe Mode: Sensor Read-Only                  ║");
  Serial.println("║   30A Continuous • 12-90V Output               ║");
  Serial.println("╚════════════════════════════════════════════════╝\n");
  
  // Initialize EEPROM
  EEPROM.begin(EEPROM_SIZE);
  Serial.println("[SETUP] EEPROM initialized");
  
  // Load calibration offset from EEPROM
  loadCalibrationOffset();
  
  // Initialize I2C and LCD
  Wire.begin(PIN_LCD_SDA, PIN_LCD_SCL);
  lcd.init();
  lcd.backlight();
  lcd.clear();
  lcd.print("Smart Charger");
  lcd.setCursor(0, 1);
  lcd.print("Initializing...");
  Serial.println("[SETUP] LCD initialized at 0x27");
  delay(2000);
  
  // Initialize ADC pins
  pinMode(PIN_ACS758_CURRENT, INPUT);
  pinMode(PIN_VOLTAGE_SENSE, INPUT);
  Serial.println("[SETUP] ADC inputs configured");
  
  // Initialize temperature sensor
  tempSensor.begin();
  Serial.println("[SETUP] Temperature sensor initialized");
  
  // Initialize filter buffers
  for (int i = 0; i < FILTER_SIZE; i++) {
    currentFilter[i] = 0.0;
    voltageFilter[i] = 0.0;
  }
  
  // Calibrate current sensor
  Serial.println("[SETUP] Calibrating ACS758 current sensor...");
  calibrateCurrentSensor();
  
  Serial.println("[SETUP] ✅ All systems ready!\n");
  
  // Show ready message on LCD
  lcd.clear();
  lcd.print("System Ready");
  lcd.setCursor(0, 1);
  lcd.print("Monitoring...");
  delay(2000);
  lcd.clear();
}

// ═══════════════════════════════════════════════════════════════
// MAIN LOOP
// ═════════════��═════════════════════════════════════════════════

void loop() {
  // Update sensor readings
  updateCurrentSensor();
  updateVoltageSensor();
  updateTemperatureSensor();
  
  // Calculate power
  powerValue = voltageValue * currentValue;
  
  // Check for anomalies
  checkSafetyLimits();
  
  // Update LCD display
  updateLcdDisplay();
  
  // Print debug info to serial
  printDebugInfo();
  
  // Small delay to prevent watchdog timeout
  delay(50);
}

// ═══════════════════════════════════════════════════════════════
// SENSOR READING FUNCTIONS
// ═══════════════════════════════════════════════════════════════

/**
 * Read current sensor (ACS758) from ADC pin 34
 * Formula: I = (Vout - 2.5V) / 0.04V + Offset
 */
void updateCurrentSensor() {
  if (millis() - lastSensorRead < SENSOR_READ_MS) return;
  lastSensorRead = millis();
  
  // Read ADC multiple times and average
  int sum = 0;
  for (int i = 0; i < ACS758_SAMPLES; i++) {
    sum += analogRead(PIN_ACS758_CURRENT);
    delayMicroseconds(100);
  }
  float adc_avg = sum / (float)ACS758_SAMPLES;
  
  // Convert ADC value to voltage (0-4095 = 0-5V)
  float vout = (adc_avg / ACS758_ADC_RESOLUTION) * ACS758_VREF;
  
  // Convert voltage to current using ACS758 formula
  // I = (Vout - Vref_mid) / Sensitivity + Calibration_offset
  float raw_current = ((vout - ACS758_VREF_MID) / ACS758_SENSITIVITY) + currentOffset;
  
  // Apply moving average filter
  currentFilter[filterIndex] = raw_current;
  float filtered_current = 0.0;
  for (int i = 0; i < FILTER_SIZE; i++) {
    filtered_current += currentFilter[i];
  }
  filtered_current /= FILTER_SIZE;
  
  // Update filter index
  filterIndex = (filterIndex + 1) % FILTER_SIZE;
  
  // Clamp small noise to zero
  if (fabs(filtered_current) < 0.1) {
    filtered_current = 0.0;
  }
  
  // Safety limit
  if (filtered_current > 35.0) {
    filtered_current = 35.0;  // Hard limit to sensor max
  }
  
  currentValue = filtered_current;
}

/**
 * Read voltage sensor from voltage divider (ADC pin 35)
 * Formula: Vin = Vout × Divider_ratio
 * Divider ratio: 18:1 (90V input = 5V output)
 */
void updateVoltageSensor() {
  if (millis() - lastSensorRead < SENSOR_READ_MS) return;
  
  // Read ADC multiple times and average
  int sum = 0;
  for (int i = 0; i < 10; i++) {
    sum += analogRead(PIN_VOLTAGE_SENSE);
    delayMicroseconds(100);
  }
  float adc_avg = sum / 10.0;
  
  // Convert ADC to voltage (0-4095 = 0-5V divider output)
  float adc_voltage = (adc_avg / VOLTAGE_ADC_RESOLUTION) * VOLTAGE_VREF;
  
  // Apply divider ratio to get actual battery voltage
  float measured_voltage = adc_voltage * VOLTAGE_DIVIDER_RATIO;
  
  // Apply moving average filter
  voltageFilter[filterIndex % FILTER_SIZE] = measured_voltage;
  float filtered_voltage = 0.0;
  for (int i = 0; i < FILTER_SIZE; i++) {
    filtered_voltage += voltageFilter[i];
  }
  filtered_voltage /= FILTER_SIZE;
  
  // Safety clamp
  if (filtered_voltage > 100.0) {
    filtered_voltage = 100.0;
  }
  if (filtered_voltage < 0.0) {
    filtered_voltage = 0.0;
  }
  
  voltageValue = filtered_voltage;
}

/**
 * Read temperature sensor (DS18B20) on OneWire
 */
void updateTemperatureSensor() {
  if (millis() - lastTempRead < TEMP_READ_MS) return;
  lastTempRead = millis();
  
  tempSensor.requestTemperatures();
  float temp = tempSensor.getTempCByIndex(0);
  
  // Validate temperature reading
  if (temp > -50.0 && temp < 125.0) {
    temperatureValue = temp;
  }
}

// ═══════════════════════════════════════════════════════════════
// CALIBRATION FUNCTIONS
// ═══════════════════════════════════════════════════════════════

/**
 * Calibrate ACS758 current sensor
 * Must be called with NO current flowing through sensor!
 */
void calibrateCurrentSensor() {
  Serial.println("[CALIBRATION] Starting ACS758 calibration...");
  Serial.println("[CALIBRATION] ⚠️  ENSURE NO CURRENT IS FLOWING!");
  
  // Wait for user to ensure no current
  delay(1000);
  
  // Read voltage 50 times
  float sum = 0.0;
  for (int i = 0; i < 50; i++) {
    int adc = analogRead(PIN_ACS758_CURRENT);
    float v = (adc / (float)ACS758_ADC_RESOLUTION) * ACS758_VREF;
    sum += v;
    delay(20);
  }
  
  // Calculate average zero voltage
  float zero_voltage = sum / 50.0;
  
  // Calculate offset
  // At 0A, Vout should be 2.5V
  // If actual is different, we need offset
  currentOffset = (ACS758_VREF_MID - zero_voltage) / ACS758_SENSITIVITY;
  
  // Save to EEPROM
  saveCalibrationOffset();
  
  Serial.printf("[CALIBRATION] ✅ Complete!\n");
  Serial.printf("[CALIBRATION] Zero voltage: %.4f V\n", zero_voltage);
  Serial.printf("[CALIBRATION] Calibration offset: %.6f A\n", currentOffset);
}

/**
 * Save calibration offset to EEPROM
 */
void saveCalibrationOffset() {
  uint32_t offset_bits = *(uint32_t*)&currentOffset;
  EEPROM.write(ADDR_CALIB_OFFSET + 0, (offset_bits >> 24) & 0xFF);
  EEPROM.write(ADDR_CALIB_OFFSET + 1, (offset_bits >> 16) & 0xFF);
  EEPROM.write(ADDR_CALIB_OFFSET + 2, (offset_bits >> 8) & 0xFF);
  EEPROM.write(ADDR_CALIB_OFFSET + 3, offset_bits & 0xFF);
  EEPROM.commit();
  Serial.println("[EEPROM] Calibration offset saved");
}

/**
 * Load calibration offset from EEPROM
 */
void loadCalibrationOffset() {
  uint32_t offset_bits = 0;
  offset_bits |= ((uint32_t)EEPROM.read(ADDR_CALIB_OFFSET + 0)) << 24;
  offset_bits |= ((uint32_t)EEPROM.read(ADDR_CALIB_OFFSET + 1)) << 16;
  offset_bits |= ((uint32_t)EEPROM.read(ADDR_CALIB_OFFSET + 2)) << 8;
  offset_bits |= EEPROM.read(ADDR_CALIB_OFFSET + 3);
  currentOffset = *(float*)&offset_bits;
  
  if (currentOffset == 0.0) {
    Serial.println("[EEPROM] No saved calibration found (will calibrate at startup)");
  } else {
    Serial.printf("[EEPROM] Loaded calibration offset: %.6f A\n", currentOffset);
  }
}

// ═══════════════════════════════════════════════════════════════
// SAFETY CHECK FUNCTIONS
// ═══════════════════════════════════════════════════════════════

/**
 * Check if readings exceed safe limits
 * NOTE: This is monitoring only - no hardware control!
 */
void checkSafetyLimits() {
  // Reset alert flags
  alertOverCurrent = false;
  alertOverVoltage = false;
  alertOverTemp = false;
  
  // Check current limit
  if (currentValue > MAX_SAFE_CURRENT) {
    alertOverCurrent = true;
    Serial.printf("⚠️  WARNING: Current exceeds safe limit! %.1f A > %.1f A\n",
      currentValue, MAX_SAFE_CURRENT);
  }
  
  // Check voltage limit
  if (voltageValue > MAX_SAFE_VOLTAGE) {
    alertOverVoltage = true;
    Serial.printf("⚠️  WARNING: Voltage exceeds safe limit! %.1f V > %.1f V\n",
      voltageValue, MAX_SAFE_VOLTAGE);
  }
  
  // Check temperature limit
  if (temperatureValue > MAX_SAFE_TEMP) {
    alertOverTemp = true;
    Serial.printf("⚠️  WARNING: Temperature exceeds safe limit! %.1f °C > %.1f °C\n",
      temperatureValue, MAX_SAFE_TEMP);
  }
}

// ═══════════════════════════════════════════════════════════════
// DISPLAY FUNCTIONS
// ═══════════════════════════════════════════════════════════════

/**
 * Update LCD display with current sensor readings
 * Display format:
 * Line 0: V: XX.X  I: XX.X
 * Line 1: P: XXXW  T:XX.X°C
 */
void updateLcdDisplay() {
  if (millis() - lastLcdUpdate < LCD_REFRESH_MS) return;
  lastLcdUpdate = millis();
  
  // Line 0: Voltage and Current
  lcd.setCursor(0, 0);
  lcd.printf("V:%5.1f  I:%5.1f", voltageValue, currentValue);
  
  // Line 1: Power and Temperature
  lcd.setCursor(0, 1);
  lcd.printf("P:%5.0fW T:%4.1fC", powerValue, temperatureValue);
  
  // Show alerts if active
  if (alertOverCurrent || alertOverVoltage || alertOverTemp) {
    showAlertOnLcd();
  }
}

/**
 * Show alert message on LCD
 */
void showAlertOnLcd() {
  lcd.clear();
  lcd.print("! ALERT !");
  lcd.setCursor(0, 1);
  
  if (alertOverCurrent) {
    lcd.printf("I:%.1f A HIGH!", currentValue);
  } else if (alertOverVoltage) {
    lcd.printf("V:%.1f V HIGH!", voltageValue);
  } else if (alertOverTemp) {
    lcd.printf("T:%.1f C HIGH!", temperatureValue);
  }
  
  delay(3000);  // Show alert for 3 seconds
  lcd.clear();
}

// ═══════════════════════════════════════════════════════════════
// DEBUG FUNCTIONS
// ═══════════════════════════════════════════════════════════════

/**
 * Print debug information to serial every 5 seconds
 */
void printDebugInfo() {
  if (millis() - lastDebugPrint < SERIAL_DEBUG_MS) return;
  lastDebugPrint = millis();
  
  // Print header
  Serial.println("─────────────────────────────────────────");
  
  // Print sensor values
  Serial.printf("📊 SENSOR READINGS:\n");
  Serial.printf("   Voltage:     %.2f V\n", voltageValue);
  Serial.printf("   Current:     %.2f A\n", currentValue);
  Serial.printf("   Power:       %.2f W\n", powerValue);
  Serial.printf("   Temperature: %.2f °C\n", temperatureValue);
  
  // Print alert status
  Serial.printf("\n🚨 SAFETY STATUS:\n");
  Serial.printf("   Over-current: %s (limit: %.1f A)\n",
    alertOverCurrent ? "⚠️  YES" : "✓ OK", MAX_SAFE_CURRENT);
  Serial.printf("   Over-voltage: %s (limit: %.1f V)\n",
    alertOverVoltage ? "⚠️  YES" : "✓ OK", MAX_SAFE_VOLTAGE);
  Serial.printf("   Over-temp:    %s (limit: %.1f °C)\n",
    alertOverTemp ? "⚠️  YES" : "✓ OK", MAX_SAFE_TEMP);
  
  // Print system info
  Serial.printf("\n⚙️  SYSTEM INFO:\n");
  Serial.printf("   Uptime:      %lu seconds\n", millis() / 1000);
  Serial.printf("   Offset:      %.6f A (calibration)\n", currentOffset);
  Serial.printf("   Free RAM:    %d bytes\n", ESP.getFreeHeap());
  
  Serial.println("─────────────────────────────────────────\n");
}

